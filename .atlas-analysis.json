  "keyFeatures": [
    "Auto-restore English words typed with Vietnamese IME",
    "ESC key to restore mistyped words",
    "Smart per-app input mode switching",
    "Automatic input source following",
    "Telex and VNI input methods",
    "Modern tone placement rules",
    "Auto-capitalize sentences",
    "Custom shortcuts",
    "Per-app delay configuration",
    "Offline, no data collection"
  ],
  "publicApiSurface": [
    "ime_init() - Initialize IME engine",
    "ime_key(key, caps, ctrl) - Process keystroke",
    "ime_key_ext(key, caps, ctrl, shift) - Process keystroke with shift",
    "ime_clear() - Clear buffer on word boundary",
    "ime_method(method) - Set input method (0=Telex, 1=VNI)",
    "ime_shortcut_add(from, to) - Add custom shortcut",
    "ime_shortcut_remove(from) - Remove shortcut",
    "ime_tone_position(mode) - Set tone placement mode",
    "ime_auto_capitalize(enabled) - Toggle auto-capitalization",
    "ime_free(result) - Free result pointer"
  ]
